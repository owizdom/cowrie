# Cowrie configuration
#
# Every value below has a working default in orchestration/cowrie/config.py, so
# this file is optional. Copy it to .env only if you want to change something.
#
# There are no production credentials here and none are needed: every payment
# partner is simulated and the chain is local.

# ---- datastores -----------------------------------------------------------
# Default is a local SQLite file, so the project runs with no infrastructure.
# Uncomment for the PostgreSQL 15 that SRS 2.4 specifies (see docker-compose.yml).
# COWRIE_DATABASE_URL=postgresql+psycopg://cowrie:cowrie@localhost:5432/cowrie

# Optional. Without it, the cache and rate limiter fall back to in-process.
# COWRIE_REDIS_URL=redis://localhost:6379/0

# ---- security -------------------------------------------------------------
# Change this for any deployment. The default is a known string.
# COWRIE_JWT_SECRET=change-me

# ---- chain ----------------------------------------------------------------
# simulated : in-process model of Base. The default. Nothing leaves the machine.
# anvil     : the real Solidity contracts on a local Anvil node.
#             Run `make anvil` and `make chain` first.
# Neither mode contacts Base mainnet or Base Sepolia.
# COWRIE_CHAIN_MODE=simulated
# COWRIE_ANVIL_RPC_URL=http://127.0.0.1:8545

# ---- demo -----------------------------------------------------------------
# Divides every simulated delay. 1.0 keeps the real timings, so a transfer takes
# about 30 seconds and demonstrates NFR 1 honestly. Raise it to speed up tests.
# COWRIE_DEMO_SPEED=1.0

# Set to anything other than "demo" to unmount the /demo scenario controls.
# COWRIE_ENVIRONMENT=demo

# ---- corridor pricing (FR 2.1) --------------------------------------------
# Static in this build so the demo produces the same figures every run.
# COWRIE_MID_MARKET_NGN_PER_USD=1530.00
# COWRIE_MID_MARKET_KES_PER_USD=129.50
# COWRIE_FX_SPREAD_BPS=35
# COWRIE_LIQUIDITY_SPREAD_BPS=15
# COWRIE_COWRIE_FEE_BPS=40

# ---- settlement (FR 3.3, NFR 3) -------------------------------------------
# COWRIE_REQUIRED_CONFIRMATIONS=12
# COWRIE_BASE_BLOCK_SECONDS=2.0
# COWRIE_QUOTE_LOCK_SECONDS=60
# COWRIE_STUCK_CANCEL_SECONDS=300
# COWRIE_STUCK_REFUND_SECONDS=600

# ---- one-time code delivery (FR 1.1) --------------------------------------
# Leave unset and the code is shown on screen. Set these four and codes are
# emailed for real. Gmail works with an app password (not your normal one):
#   https://myaccount.google.com/apppasswords
# COWRIE_SMTP_HOST=smtp.gmail.com
# COWRIE_SMTP_PORT=587
# COWRIE_SMTP_USER=you@gmail.com
# COWRIE_SMTP_PASSWORD=your-16-char-app-password
# COWRIE_SMTP_FROM=Cowrie <you@gmail.com>
